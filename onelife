// ── ENCRYPT UI ────────────────────────────────────────────────────
async function doEncrypt(){
  const msg=document.getElementById('enc-input').value.trim();
  if(!msg){alert('Enter a message.');return;}
  const pass=document.getElementById('enc-pass').value;
  if(['aes-gcm','chacha20','aes-cbc'].includes(selMode)&&!pass){alert('Enter a password.');return;}
  const btn=document.getElementById('enc-btn');
  btn.classList.add('loading');btn.disabled=true;
  showP('enc-progress',20);await slp(60);showP('enc-progress',55);
  const plain=eb(msg);
  const extMap={ode:'ode','aes-gcm':'enc',chacha20:'cc20','aes-cbc':'cbc',hybrid:'hyb'};
  const lblMap={ode:'ODE · AES-256-GCM + SHA3-512 · ONE-TIME','aes-gcm':'AES-256-GCM + PBKDF2',chacha20:'ChaCha20-Poly1305','aes-cbc':'AES-256-CBC + HMAC-SHA256',hybrid:'Hybrid RSA-2048 + AES-256-GCM'};
  try{
    await slp(60);showP('enc-progress',80);
    let bytes;
    if(selMode==='ode')      bytes=await odeEncrypt(plain);
    else if(selMode==='aes-gcm')  bytes=await aesEnc(plain,pass);
    else if(selMode==='chacha20') bytes=await cc20Enc(plain,pass);
    else if(selMode==='aes-cbc')  bytes=await cbcEnc(plain,pass);
    else                          bytes=await hybEnc(plain);
    showP('enc-progress',100);await slp(120);
    const hex=Array.from(bytes.slice(0,32)).map(b=>b.toString(16).padStart(2,'0')).join(' ')+' ...';
    const out=document.getElementById('enc-output');
    document.getElementById('enc-output-text').textContent=hex;
    out.style.display='block';out.className='output-box has-content success';
    const ts=new Date().toISOString().replace(/[:.]/g,'-').slice(0,19);
    const fname=`1life-${ts}.${extMap[selMode]}`;
    const url=URL.createObjectURL(new Blob([bytes],{type:'application/octet-stream'}));
    document.getElementById('dl-link').href=url;document.getElementById('dl-link').download=fname;
    document.getElementById('dl-name').textContent=fname;
    document.getElementById('dl-meta').textContent=fmtB(bytes.length)+' · '+lblMap[selMode];
    document.getElementById('enc-download').classList.add('show');
    if(selMode==='ode'){
      const info=odeInspect(bytes);
      const meta=document.getElementById('enc-blob-meta');
      meta.innerHTML=`
        <div class="blob-meta-item"><div class="blob-meta-key">Mode</div><div class="blob-meta-val">ODE v1</div></div>
        <div class="blob-meta-item"><div class="blob-meta-key">Salt</div><div class="blob-meta-val" style="font-family:var(--mono);font-size:11px">${toHex(bytes.slice(4,36))}</div></div>
        <div class="blob-meta-item"><div class="blob-meta-key">Nonce</div><div class="blob-meta-val" style="font-family:var(--mono);font-size:11px">${toHex(bytes.slice(36,52))}</div></div>
        <div class="blob-meta-item"><div class="blob-meta-key">Chain</div><div class="blob-meta-val" style="font-family:var(--mono);font-size:11px">${toHex(bytes.slice(52,116))}</div></div>
        <div class="blob-meta-item"><div class="blob-meta-key">Size</div><div class="blob-meta-val">${fmtB(bytes.length)}</div></div>
        <div class="blob-meta-item"><div class="blob-meta-key">Status</div><div class="blob-meta-val" style="color:var(--green)">${info.status}</div></div>`;
      meta.style.display='grid';
    }
    document.getElementById('enc-status-text').textContent='Encrypted · '+fmtB(bytes.length)+' · '+lblMap[selMode];
    document.getElementById('enc-status').style.display='flex';
  }catch(e){
    const out=document.getElementById('enc-output');
    document.getElementById('enc-output-text').textContent='Error: '+e.message;
    out.style.display='block';out.className='output-box has-content error';
  }
  hideP('enc-progress');btn.classList.remove('loading');btn.disabled=false;
}
function clearEncrypt(){
  ['enc-input','enc-pass'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('enc-output').style.display='none';
  document.getElementById('enc-download').classList.remove('show');
  document.getElementById('enc-status').style.display='none';
  document.getElementById('enc-blob-meta').style.display='none';
}

// ── DECRYPT UI ────────────────────────────────────────────────────
async function onBlobSelected(input){
  if(!input.files.length)return;
  const file=input.files[0];
  const reader=new FileReader();
  reader.onload=async(e)=>{
    loadedBlob=new Uint8Array(e.target.result);
    detMode=detectMode(loadedBlob);
    const passGrp=document.getElementById('dec-pass-group');
    passGrp.style.display=['aes-gcm','chacha20','aes-cbc'].includes(detMode)?'block':'none';
    const decBtn=document.getElementById('dec-btn');
    decBtn.style.fontSize='';decBtn.innerHTML='<div class="spinner"></div>Decrypt';
    document.getElementById('dec-output').style.display='none';
    document.getElementById('destroyed-banner').classList.remove('show');
    document.getElementById('dec-status').style.display='none';

    let fpBlocked=false;
    if(detMode==='ode') fpBlocked=await isBlobUsed(loadedBlob);

    const modeNames={ode:'ODE v1 (One-Decrypt)','aes-gcm':'AES-256-GCM',chacha20:'ChaCha20-Poly1305','aes-cbc':'AES-256-CBC+HMAC',hybrid:'Hybrid RSA+AES'};
    let statusColor='var(--green)',statusText='Ready to decrypt',canDec=true;

    if(!detMode){statusColor='var(--red)';statusText='Unknown format — not a 1LIFE file';canDec=false;}
    else if(detMode==='ode'){
      const info=odeInspect(loadedBlob);
      if(fpBlocked){statusColor='var(--red)';statusText='BLOCKED — fingerprint in used-key database';canDec=false;}
      else if(info.used){statusColor='var(--red)';statusText='DESTROYED — header zeroed';canDec=false;}
      else statusText='INTACT — ready to decrypt once';
    } else {
      statusText='Ready to decrypt (enter password)';
    }

    document.getElementById('dec-blob-info').innerHTML=`
      <div class="blob-meta-item"><div class="blob-meta-key">File</div><div class="blob-meta-val">${file.name}</div></div>
      <div class="blob-meta-item"><div class="blob-meta-key">Size</div><div class="blob-meta-val">${fmtB(file.size)}</div></div>
      <div class="blob-meta-item"><div class="blob-meta-key">Mode</div><div class="blob-meta-val">${detMode?modeNames[detMode]:'Unknown'}</div></div>
      <div class="blob-meta-item"><div class="blob-meta-key">Status</div><div class="blob-meta-val" style="color:${statusColor}">${statusText}</div></div>`;
    document.getElementById('dec-inspect-area').style.display='block';
    decBtn.disabled=!canDec;
  };
  reader.readAsArrayBuffer(file);
}

async function doDecrypt(){
  if(!loadedBlob)return;
  const pass=document.getElementById('dec-pass').value;
  if(['aes-gcm','chacha20','aes-cbc'].includes(detMode)&&!pass){alert('Enter the password.');return;}
  const btn=document.getElementById('dec-btn');
  const out=document.getElementById('dec-output');
  const outTxt=document.getElementById('dec-output-text');
  const dot=document.getElementById('dec-dot');
  const stTxt=document.getElementById('dec-status-text');
  btn.classList.add('loading');btn.disabled=true;
  showP('dec-progress',30);await slp(100);showP('dec-progress',65);await slp(80);showP('dec-progress',90);
  try{
    let plain,wasODE=false,destroyed=null;
    switch(detMode){
      case 'ode':{const r=await odeDecrypt(loadedBlob);plain=r.plain;destroyed=r.destroyed;wasODE=true;break;}
      case 'aes-gcm': plain=await aesDec(loadedBlob,pass);break;
      case 'chacha20': plain=await cc20Dec(loadedBlob,pass);break;
      case 'aes-cbc':  plain=await cbcDec(loadedBlob,pass);break;
      case 'hybrid':   plain=await hybDec(loadedBlob);break;
      default: throw new Error("Unknown file format.");
    }
    showP('dec-progress',100);await slp(120);
    let display;
    try{display=new TextDecoder('utf-8',{fatal:true}).decode(plain);}
    catch{display='[Binary content — '+fmtB(plain.length)+']';}
    outTxt.textContent=display;
    out.style.display='block';out.className='output-box has-content success';
    document.getElementById('dec-status').style.display='flex';
    if(wasODE&&destroyed){
      // Replace in-memory with destroyed — belt-and-suspenders layer
      loadedBlob=destroyed;
      btn.disabled=true;btn.style.fontSize='10px';btn.innerHTML='☠ Permanently Destroyed';
      document.getElementById('destroyed-banner').classList.add('show');
      const dlUrl=URL.createObjectURL(new Blob([destroyed],{type:'application/octet-stream'}));
      document.getElementById('dec-blob-info').innerHTML+=`
        <div class="blob-meta-item" style="grid-column:1/-1;background:#0d0404;border-left:3px solid var(--red)">
          <div class="blob-meta-key">Post-decrypt</div>
          <div class="blob-meta-val" style="color:var(--red)">ZEROED + FINGERPRINT SAVED · <a href="${dlUrl}" download="destroyed.ode" style="color:var(--amber)">Download destroyed blob</a></div>
        </div>`;
      dot.className='status-dot dot-red';
      stTxt.textContent='ODE blob destroyed. 3 layers armed. Cannot decrypt again on this device.';
    }else{
      dot.className='status-dot dot-green';
      stTxt.textContent='Decrypted successfully.';
      btn.classList.remove('loading');btn.disabled=false;
    }
  }catch(e){
    outTxt.textContent=e.message;
    out.style.display='block';
    if(e.message.startsWith('ALREADY_USED')){
      out.className='output-box has-content destroyed';
      btn.disabled=true;btn.innerHTML='☠ Blob Used';
      dot.className='status-dot dot-amber';
      stTxt.textContent='Blocked by fingerprint database. Layer '+(e.layer||'?')+' triggered.';
    }else{
      out.className='output-box has-content error';
      dot.className='status-dot dot-red';
      stTxt.textContent='Failed: '+e.message.split('.')[0];
      btn.classList.remove('loading');btn.disabled=false;
    }
    document.getElementById('dec-status').style.display='flex';
  }
  hideP('dec-progress');btn.classList.remove('loading');
}

function clearDecrypt(){
  document.getElementById('dec-file').value='';
  ['dec-inspect-area','dec-output','dec-status'].forEach(id=>document.getElementById(id).style.display='none');
  document.getElementById('dec-pass-group').style.display='none';
  document.getElementById('dec-pass').value='';
  document.getElementById('destroyed-banner').classList.remove('show');
  const btn=document.getElementById('dec-btn');
  btn.disabled=true;btn.style.fontSize='';
  btn.innerHTML='<div class="spinner"></div>Decrypt';
  loadedBlob=null;detMode=null;
}

function copyOutput(id){
  navigator.clipboard.writeText(document.getElementById(id).textContent).then(()=>{
    const b=event.target;b.textContent='Copied';setTimeout(()=>b.textContent='Copy',1500);
  });
}

document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('enc-input').addEventListener('keydown',e=>{
    if(e.ctrlKey&&e.key==='Enter')doEncrypt();
  });
});
</script>
