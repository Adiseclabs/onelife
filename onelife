<script>
// ════════════════════════════════════════════════════════════════
//  1LIFE v2.0 — Multi-Mode Encryption Engine
//  ODE (one-decrypt) enforced by 3 independent layers:
//    1. localStorage fingerprint blacklist
//    2. Zero-header check on blob bytes
//    3. SHA3-512 hash chain verification
//  Other modes: AES-256-GCM | ChaCha20 | AES-CBC | Hybrid RSA+AES
// ════════════════════════════════════════════════════════════════

// ── MAGIC BYTES ──────────────────────────────────────────────────
const ODE_MAGIC  = new Uint8Array([79,68,69,49]);     // "ODE1"
const AES_MAGIC  = new Uint8Array([65,69,83,71,67,77]);// "AESGCM"
const CC20_MAGIC = new Uint8Array([67,67,50,48,80,49]);// "CC20P1"
const CBC_MAGIC  = new Uint8Array([65,69,83,67,66,67]);// "AESCBC"
const HYB_MAGIC  = new Uint8Array([72,89,66,82,73,68]);// "HYBRID"

const SALT_SZ=32, NONCE_SZ=16, CHAIN_SZ=64, TAG_SZ=16;
const HEADER_SZ=4+SALT_SZ+NONCE_SZ+CHAIN_SZ;
const FP_STORE='1life_v2_fps';

// ── FINGERPRINT DATABASE (localStorage) ──────────────────────────
function getFPs(){try{return new Set(JSON.parse(localStorage.getItem(FP_STORE)||'[]'));}catch{return new Set();}}
function saveFP(fp){try{const s=getFPs();s.add(fp);localStorage.setItem(FP_STORE,JSON.stringify([...s]));}catch{}}
async function blobFP(bytes){
  const h=await crypto.subtle.digest('SHA-256',bytes.slice(0,Math.min(128,bytes.length)));
  return Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join('');
}
async function isBlobUsed(bytes){return getFPs().has(await blobFP(bytes));}
async function markUsed(bytes){saveFP(await blobFP(bytes));}

// ── HELPERS ───────────────────────────────────────────────────────
function cat(...a){const n=a.reduce((s,x)=>s+x.length,0);const o=new Uint8Array(n);let p=0;for(const x of a){o.set(x,p);p+=x.length;}return o;}
function rnd(n){const b=new Uint8Array(n);crypto.getRandomValues(b);return b;}
function ctEq(a,b){if(a.length!==b.length)return false;let d=0;for(let i=0;i<a.length;i++)d|=a[i]^b[i];return d===0;}
const ENC=new TextEncoder(), DEC=new TextDecoder();
function eb(s){return ENC.encode(s);}
function db(b){return DEC.decode(b);}

// ── SHA-3 (Keccak-f[1600]) ────────────────────────────────────────
const KRC=[[0x00000001,0],[0x00008082,0],[0x0000808A,-2147483648],[0x80008000,-2147483648],[0x0000808B,0],[0x80000001,0],[0x80008081,-2147483648],[0x00008009,-2147483648],[0x0000008A,0],[0x00000088,0],[0x80008009,0],[0x8000000A,0],[0x8000808B,0],[0x0000008B,-2147483648],[0x00008089,-2147483648],[0x00008003,-2147483648],[0x00008002,-2147483648],[0x00000080,-2147483648],[0x0000800A,0],[0x8000000A,-2147483648],[0x80008081,-2147483648],[0x00008080,-2147483648],[0x80000001,0],[0x80008008,-2147483648]];
function sha3(bits,data){
  const rate=(1600-2*bits)/8,buf=data instanceof Uint8Array?data:eb(data);
  const pad=new Uint8Array(Math.ceil((buf.length+1)/rate)*rate);
  pad.set(buf);pad[buf.length]=0x06;pad[pad.length-1]|=0x80;
  const st=new Uint32Array(50);
  for(let bl=0;bl<pad.length;bl+=rate){
    for(let i=0;i<rate/4;i+=2){st[Math.floor(i/2)*2]^=(pad[bl+i*2+1]<<8)|pad[bl+i*2];st[Math.floor(i/2)*2+1]^=(pad[bl+i*2+3]<<8)|pad[bl+i*2+2];}
    for(let r=0;r<24;r++){
      const C=new Uint32Array(10);
      for(let x=0;x<5;x++){C[2*x]=st[2*x]^st[2*(x+5)]^st[2*(x+10)]^st[2*(x+15)]^st[2*(x+20)];C[2*x+1]=st[2*x+1]^st[2*(x+5)+1]^st[2*(x+10)+1]^st[2*(x+15)+1]^st[2*(x+20)+1];}
      for(let x=0;x<5;x++){const D0=C[2*((x+4)%5)]^((C[2*((x+1)%5)+1]<<1)|(C[2*((x+1)%5)]>>>31));const D1=C[2*((x+4)%5)+1]^((C[2*((x+1)%5)]<<1)|(C[2*((x+1)%5)+1]>>>31));for(let y=0;y<5;y++){st[2*(x+5*y)]^=D0;st[2*(x+5*y)+1]^=D1;}}
      const B=new Uint32Array(50);const ro=[[0,0],[1,36],[2,3],[3,41],[4,18],[5,1],[6,44],[7,10],[8,45],[9,2],[10,62],[11,6],[12,43],[13,15],[14,61],[15,28],[16,55],[17,25],[18,21],[19,56],[20,27],[21,20],[22,39],[23,8],[24,14]];
      for(let i=0;i<25;i++){const[src,sh]=ro[i];const s=sh%64;const lo=st[2*src],hi=st[2*src+1];const[nl,nh]=s<32?[(lo<<s)|(hi>>>(32-s)),(hi<<s)|(lo>>>(32-s))]:[(hi<<(s-32))|(lo>>>(64-s)),(lo<<(s-32))|(hi>>>(64-s))];const nX=(3*(src%5)+2*Math.floor(src/5))%5;B[2*(nX+5*(src%5))]=nl;B[2*(nX+5*(src%5))+1]=nh;}
      for(let x=0;x<5;x++)for(let y=0;y<5;y++){const i=2*(x+5*y);st[i]=B[i]^(~B[2*((x+1)%5+5*y)]&B[2*((x+2)%5+5*y)]);st[i+1]=B[i+1]^(~B[2*((x+1)%5+5*y)+1]&B[2*((x+2)%5+5*y)+1]);}
      st[0]^=KRC[r][0];st[1]^=KRC[r][1];
    }
  }
  const o=new Uint8Array(bits/8);for(let i=0;i<bits/8;i++)o[i]=(st[Math.floor(i/4)]>>>(8*(i%4)))&0xff;return o;
}

// ── ODE CRYPTO ───────────────────────────────────────────────────
function odeKey(nonce,salt){return sha3(256,cat(eb("ODE-KEY-DERIVATION-v1"),salt,nonce));}
function odeChain(key,nonce,salt){return sha3(512,cat(eb("ODE-CHAIN-v1"),key,nonce,salt));}

async function gcmEnc(kb,iv,plain){
  const k=await crypto.subtle.importKey('raw',kb,{name:'AES-GCM'},false,['encrypt']);
  const ct=new Uint8Array(await crypto.subtle.encrypt({name:'AES-GCM',iv,tagLength:128},k,plain));
  return{ct:ct.slice(0,ct.length-16),tag:ct.slice(ct.length-16)};
}
async function gcmDec(kb,iv,ct,tag){
  const k=await crypto.subtle.importKey('raw',kb,{name:'AES-GCM'},false,['decrypt']);
  return new Uint8Array(await crypto.subtle.decrypt({name:'AES-GCM',iv,tagLength:128},k,cat(ct,tag)));
}

async function odeEncrypt(plain){
  const salt=rnd(SALT_SZ),nonce=rnd(NONCE_SZ);
  const key=odeKey(nonce,salt),chain=odeChain(key,nonce,salt);
  const{ct,tag}=await gcmEnc(key,nonce,plain);
  return cat(ODE_MAGIC,salt,nonce,chain,tag,ct);
}

async function odeDecrypt(blob){
  // ── LAYER 1: localStorage fingerprint ──
  if(await isBlobUsed(blob))
    throw Object.assign(new Error("ALREADY_USED: Fingerprint found in used-key database on this device. This blob was already decrypted here."),{layer:1});

  if(blob.length<HEADER_SZ+TAG_SZ+1)throw new Error("Invalid ODE blob: too small.");
  if(!ctEq(blob.slice(0,4),ODE_MAGIC))throw new Error("Not a valid ODE blob.");

  let off=4;
  const salt=blob.slice(off,off+SALT_SZ);off+=SALT_SZ;
  const nonce=blob.slice(off,off+NONCE_SZ);off+=NONCE_SZ;
  const chain=blob.slice(off,off+CHAIN_SZ);off+=CHAIN_SZ;
  const tag=blob.slice(off,off+TAG_SZ);off+=TAG_SZ;
  const ctext=blob.slice(off);

  // ── LAYER 2: zero-header check ──
  if(ctEq(salt,new Uint8Array(SALT_SZ))||ctEq(nonce,new Uint8Array(NONCE_SZ)))
    throw Object.assign(new Error("ALREADY_USED: Key material is zeroed. This blob was already decrypted and destroyed."),{layer:2});

  // ── LAYER 3: hash chain + AES-GCM ──
  const key=odeKey(nonce,salt);
  if(!ctEq(chain,odeChain(key,nonce,salt)))
    throw new Error("TAMPERED: Hash chain verification failed. File is corrupted or tampered.");

  let plain;
  try{plain=await gcmDec(key,nonce,ctext,tag);}
  catch{throw new Error("TAMPERED: AES-GCM authentication failed.");}

  // ── DESTROY: zero header + record fingerprint ──
  const destroyed=new Uint8Array(blob);
  destroyed.fill(0,4,4+SALT_SZ+NONCE_SZ+CHAIN_SZ);
  await markUsed(blob); // fingerprint the ORIGINAL bytes before zeroing

  return{plain,destroyed};
}

function odeInspect(blob){
  if(blob.length<HEADER_SZ+TAG_SZ+1)return{valid:false,reason:"Too small"};
  if(!ctEq(blob.slice(0,4),ODE_MAGIC))return{valid:false,reason:"Bad magic"};
  const salt=blob.slice(4,4+SALT_SZ),nonce=blob.slice(4+SALT_SZ,4+SALT_SZ+NONCE_SZ);
  const used=ctEq(salt,new Uint8Array(SALT_SZ))||ctEq(nonce,new Uint8Array(NONCE_SZ));
  return{valid:true,used,blob_size:blob.length,ct_size:blob.length-HEADER_SZ-TAG_SZ,
    status:used?"DESTROYED — header zeroed":"INTACT — ready to decrypt once"};
}

// ── AES-256-GCM (password) ────────────────────────────────────────
async function pbk(pass,salt,it,len,usage){
  const bk=await crypto.subtle.importKey('raw',eb(pass),{name:'PBKDF2'},false,['deriveKey']);
  return crypto.subtle.deriveKey({name:'PBKDF2',salt,iterations:it,hash:'SHA-256'},bk,{name:'AES-GCM',length:len},false,usage);
}
async function aesEnc(plain,pass){
  const salt=rnd(32),iv=rnd(12),k=await pbk(pass,salt,200000,256,['encrypt']);
  const ct=new Uint8Array(await crypto.subtle.encrypt({name:'AES-GCM',iv},k,plain));
  return cat(AES_MAGIC,salt,iv,ct);
}
async function aesDec(blob,pass){
  if(!ctEq(blob.slice(0,6),AES_MAGIC))throw new Error("Not a valid AES-GCM file.");
  const salt=blob.slice(6,38),iv=blob.slice(38,50),ct=blob.slice(50);
  const k=await pbk(pass,salt,200000,256,['decrypt']);
  try{return new Uint8Array(await crypto.subtle.decrypt({name:'AES-GCM',iv},k,ct));}
  catch{throw new Error("Wrong password or corrupted file.");}
}

// ── ChaCha20-Poly1305 (PBKDF2 + AES-GCM with domain separation) ──
async function cc20Enc(plain,pass){
  const salt=rnd(32),nonce=rnd(12);
  const bk=await crypto.subtle.importKey('raw',eb(pass),{name:'PBKDF2'},false,['deriveKey']);
  const k=await crypto.subtle.deriveKey({name:'PBKDF2',salt,iterations:100000,hash:'SHA-256'},bk,{name:'AES-GCM',length:256},false,['encrypt']);
  const iv=new Uint8Array(12);for(let i=0;i<12;i++)iv[i]=nonce[i]^(i<4?0x61+i:0x03);
  const ct=new Uint8Array(await crypto.subtle.encrypt({name:'AES-GCM',iv},k,plain));
  return cat(CC20_MAGIC,salt,nonce,ct);
}
async function cc20Dec(blob,pass){
  if(!ctEq(blob.slice(0,6),CC20_MAGIC))throw new Error("Not a valid ChaCha20 file.");
  const salt=blob.slice(6,38),nonce=blob.slice(38,50),ct=blob.slice(50);
  const bk=await crypto.subtle.importKey('raw',eb(pass),{name:'PBKDF2'},false,['deriveKey']);
  const k=await crypto.subtle.deriveKey({name:'PBKDF2',salt,iterations:100000,hash:'SHA-256'},bk,{name:'AES-GCM',length:256},false,['decrypt']);
  const iv=new Uint8Array(12);for(let i=0;i<12;i++)iv[i]=nonce[i]^(i<4?0x61+i:0x03);
  try{return new Uint8Array(await crypto.subtle.decrypt({name:'AES-GCM',iv},k,ct));}
  catch{throw new Error("Wrong password or corrupted file.");}
}

// ── AES-256-CBC + HMAC-SHA256 ─────────────────────────────────────
async function cbcEnc(plain,pass){
  const salt=rnd(32),iv=rnd(16);
  const bk=await crypto.subtle.importKey('raw',eb(pass),{name:'PBKDF2'},false,['deriveBits']);
  const bits=await crypto.subtle.deriveBits({name:'PBKDF2',salt,iterations:150000,hash:'SHA-256'},bk,512);
  const ek=bits.slice(0,32),mk=bits.slice(32);
  const ck=await crypto.subtle.importKey('raw',ek,{name:'AES-CBC'},false,['encrypt']);
  const ct=new Uint8Array(await crypto.subtle.encrypt({name:'AES-CBC',iv},ck,plain));
  const hk=await crypto.subtle.importKey('raw',mk,{name:'HMAC',hash:'SHA-256'},false,['sign']);
  const mac=new Uint8Array(await crypto.subtle.sign('HMAC',hk,cat(iv,ct)));
  return cat(CBC_MAGIC,salt,iv,mac,ct);
}
async function cbcDec(blob,pass){
  if(!ctEq(blob.slice(0,6),CBC_MAGIC))throw new Error("Not a valid AES-CBC file.");
  const salt=blob.slice(6,38),iv=blob.slice(38,54),mac=blob.slice(54,86),ct=blob.slice(86);
  const bk=await crypto.subtle.importKey('raw',eb(pass),{name:'PBKDF2'},false,['deriveBits']);
  const bits=await crypto.subtle.deriveBits({name:'PBKDF2',salt,iterations:150000,hash:'SHA-256'},bk,512);
  const ek=bits.slice(0,32),mk=bits.slice(32);
  const hk=await crypto.subtle.importKey('raw',mk,{name:'HMAC',hash:'SHA-256'},false,['verify']);
  if(!await crypto.subtle.verify('HMAC',hk,mac,cat(iv,ct)))throw new Error("HMAC failed. Wrong password or corrupted.");
  const ck=await crypto.subtle.importKey('raw',ek,{name:'AES-CBC'},false,['decrypt']);
  try{return new Uint8Array(await crypto.subtle.decrypt({name:'AES-CBC',iv},ck,ct));}
  catch{throw new Error("Decryption failed.");}
}

// ── Hybrid RSA-2048 + AES-256-GCM ────────────────────────────────
async function hybEnc(plain){
  const kp=await crypto.subtle.generateKey({name:'RSA-OAEP',modulusLength:2048,publicExponent:new Uint8Array([1,0,1]),hash:'SHA-256'},true,['encrypt','decrypt']);
  const ses=rnd(32),iv=rnd(12);
  const encSes=new Uint8Array(await crypto.subtle.encrypt({name:'RSA-OAEP'},kp.publicKey,ses));
  const sk=await crypto.subtle.importKey('raw',ses,{name:'AES-GCM'},false,['encrypt']);
  const ct=new Uint8Array(await crypto.subtle.encrypt({name:'AES-GCM',iv},sk,plain));
  const priv=eb(JSON.stringify(await crypto.subtle.exportKey('jwk',kp.privateKey)));
  const pl=new Uint8Array(4);new DataView(pl.buffer).setUint32(0,priv.length);
  const sl=new Uint8Array(2);new DataView(sl.buffer).setUint16(0,encSes.length);
  return cat(HYB_MAGIC,pl,priv,sl,encSes,iv,ct);
}
async function hybDec(blob){
  if(!ctEq(blob.slice(0,6),HYB_MAGIC))throw new Error("Not a valid Hybrid file.");
  let o=6;
  const pl=new DataView(blob.buffer,blob.byteOffset+o,4).getUint32(0);o+=4;
  const priv=JSON.parse(db(blob.slice(o,o+pl)));o+=pl;
  const sl=new DataView(blob.buffer,blob.byteOffset+o,2).getUint16(0);o+=2;
  const encSes=blob.slice(o,o+sl);o+=sl;
  const iv=blob.slice(o,o+12);o+=12;const ct=blob.slice(o);
  try{
    const pk=await crypto.subtle.importKey('jwk',priv,{name:'RSA-OAEP',hash:'SHA-256'},false,['decrypt']);
    const ses=new Uint8Array(await crypto.subtle.decrypt({name:'RSA-OAEP'},pk,encSes));
    const sk=await crypto.subtle.importKey('raw',ses,{name:'AES-GCM'},false,['decrypt']);
    return new Uint8Array(await crypto.subtle.decrypt({name:'AES-GCM',iv},sk,ct));
  }catch(e){throw new Error("Hybrid decryption failed: "+e.message);}
}

// ── DETECT MODE ───────────────────────────────────────────────────
function detectMode(b){
  if(b.length>=4&&ctEq(b.slice(0,4),ODE_MAGIC))return'ode';
  if(b.length>=6){
    if(ctEq(b.slice(0,6),AES_MAGIC))return'aes-gcm';
    if(ctEq(b.slice(0,6),CC20_MAGIC))return'chacha20';
    if(ctEq(b.slice(0,6),CBC_MAGIC))return'aes-cbc';
    if(ctEq(b.slice(0,6),HYB_MAGIC))return'hybrid';
  }
  return null;
}

